# ==============================================================================
# N.E.X.U.S — Environment Variables (Dev)
# ==============================================================================
# Copy ke .env dan sesuaikan. Jangan commit .env ke repo.
# ==============================================================================

# ---- Workspace root untuk agent runtime ----
# Agent akan eksekusi di dalam path ini (subdirectory = project slug)
NEXUS_WORKSPACE_ROOT=/home/kurniarahmat/coding

# ---- Rocket.Chat ----
ROCKETCHAT_URL=http://localhost:3000
ROCKETCHAT_ADMIN_USERNAME=admin
ROCKETCHAT_ADMIN_PASSWORD=nexus_admin_dev
ROCKETCHAT_ADMIN_EMAIL=admin@nexus.local

# ---- MongoDB (untuk Rocket.Chat) ----
# Tidak perlu secret di dev, replica set lokal saja

# ---- Postgres + pgvector ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev_pass
POSTGRES_DB=nexus
# URL lengkap untuk service host (Bun) yang connect dari luar container
DATABASE_URL=postgresql://nexus:nexus_dev_pass@localhost:5433/nexus

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380

# ---- Mem0 API (sidecar service) ----
MEM0_API_URL=http://localhost:4100

# ---- Nexus Services (host processes) ----
GATEWAY_PORT=4000
COMPOSER_PORT=4001
RUNTIME_PORT=4002

# ---- Webhook shared secret (RC → Gateway) ----
# RC posts this as 'token' field; gateway validates.
# Ganti kalau sudah production; dev biarkan default.
NEXUS_WEBHOOK_TOKEN=nexus_webhook_dev_secret

# ---- LLM for Mem0 (fact extraction + summarization) ----
# Pakai OpenAI-compatible endpoint. Default: vLLM gemma-4-31B Mas.
MEM0_LLM_PROVIDER=openai
MEM0_LLM_MODEL=QuantTrio/gemma-4-31B-it-AWQ
MEM0_LLM_BASE_URL=https://a100gemma.acciox.dev/v1
MEM0_LLM_API_KEY=dummy

# ---- Embedder for Mem0 (local HuggingFace) ----
MEM0_EMBEDDER_PROVIDER=huggingface
MEM0_EMBEDDER_MODEL=sentence-transformers/all-MiniLM-L6-v2
MEM0_EMBEDDING_DIMS=384

# ---- (optional) real provider keys — unused if MEM0_LLM_* set ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- CLI Binary Paths (resolved oleh runtime) ----
CLAUDE_BIN=/home/kurniarahmat/.local/bin/claude
HERMES_BIN=/home/kurniarahmat/.local/bin/hermes
CURSOR_BIN=/home/kurniarahmat/.local/bin/agent
GEMINI_BIN=/home/kurniarahmat/.local/bin/gemini
GEMINI_MODEL=gemini-2.5-flash

# ---- Logging ----
LOG_LEVEL=info
NODE_ENV=development
