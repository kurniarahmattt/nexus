# ==============================================================================
# N.E.X.U.S — Environment Variables (Dev)
# ==============================================================================
# Copy this file to .env and edit values to match your setup.
# Never commit .env — it is gitignored on purpose.
# ==============================================================================

# ---- Workspace root for the agent runtime ----
# The agent executes inside this path (each subdirectory = project slug).
# REQUIRED, must be an absolute path. Example: /home/yourname/coding
NEXUS_WORKSPACE_ROOT=/path/to/your/coding-root

# ---- Rocket.Chat ----
# Port should match ROCKETCHAT_HOST_PORT below.
ROCKETCHAT_URL=http://localhost:3000
ROCKETCHAT_ADMIN_USERNAME=admin
ROCKETCHAT_ADMIN_PASSWORD=nexus_admin_dev
ROCKETCHAT_ADMIN_EMAIL=admin@nexus.local

# ---- MongoDB (used by Rocket.Chat) ----
# No secret needed in dev; we run a single-node replica set locally.

# ---- Docker stack host ports ----
# These map the container's internal port to your host. Change ONLY if
# something else on this machine is already using the default. The
# wizard `nexus host-onboard` will detect conflicts and offer to
# auto-relocate; if you set them manually, also update DATABASE_URL,
# REDIS_URL, MEM0_API_URL, ROCKETCHAT_URL below to match.
ROCKETCHAT_HOST_PORT=3000
MONGO_HOST_PORT=27017
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380
MEM0_HOST_PORT=4100

# ---- Postgres + pgvector ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev_pass
POSTGRES_DB=nexus
# Full URL for host services (Bun) that connect from outside the container.
# Port should match POSTGRES_HOST_PORT above.
DATABASE_URL=postgresql://nexus:nexus_dev_pass@localhost:5433/nexus

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6380
# Port should match REDIS_HOST_PORT above.
REDIS_URL=redis://localhost:6380

# ---- Mem0 API (sidecar service) ----
# Port should match MEM0_HOST_PORT above.
MEM0_API_URL=http://localhost:4100

# ---- Nexus Services (host processes — bind directly to these ports) ----
# Auto-relocated by `nexus host-onboard` if defaults clash with another
# process on this machine.
GATEWAY_PORT=4000
COMPOSER_PORT=4001
RUNTIME_PORT=4002

# ---- Webhook shared secret (Rocket.Chat → Gateway) ----
# RC posts this as the 'token' field; the gateway validates it.
# Change before any production-like deployment; leave the default in dev.
NEXUS_WEBHOOK_TOKEN=nexus_webhook_dev_secret

# ---- Admin Web UI session secret (cookie signing) ----
# At least 16 chars. `nexus host-onboard` regenerates this from openssl.
NEXUS_SESSION_SECRET=nexus_dev_session_secret_at_least_16

# ---- Admin Web UI bearer token (one-shot login) ----
# Used by the Web UI's /api/auth/login. `nexus host-onboard` regenerates.
NEXUS_ADMIN_TOKEN=nexus_admin_token_dev

# ---- Public-facing base URL for join links + bridge WebSocket ----
# Used when issuing one-shot bridge join URLs (`make create-bridge` /
# `make issue-join-link`). Must be reachable from the developer's laptop.
# Examples:
#   • LAN host:           http://192.168.1.10:4000
#   • Tailscale mesh:     http://100.x.y.z:4000
#   • Public TLS deploy:  https://nexus.team.com
# WS form is derived automatically (http→ws, https→wss).
NEXUS_PUBLIC_URL=http://localhost:4000

# ---- Default TTL for issued join codes (hours) ----
# Lower = more friction (link must be used quickly). Higher = more leak
# risk if the link is screenshotted. 24 is a reasonable default.
NEXUS_JOIN_TTL_HOURS=24

# ---- Default TTL for bridge invites (hours) ----
# Invites let teammates create their own bridges via `nexus request-bridge`.
# Longer than join TTL because invites are typically issued once per dev
# and may sit unused for days. Override per-issue with NEXUS_INVITE_TTL_HOURS=N.
NEXUS_INVITE_TTL_HOURS=72

# ---- LLM for Mem0 (fact extraction + summarization) ----
# Use any OpenAI-compatible endpoint (OpenAI, Anthropic via gateway, local
# vLLM, etc.). For a local vLLM: run `vllm serve <model>` and point
# BASE_URL at http://localhost:8000/v1 (the default vLLM port).
MEM0_LLM_PROVIDER=openai
MEM0_LLM_MODEL=gpt-4o-mini
MEM0_LLM_BASE_URL=https://api.openai.com/v1
MEM0_LLM_API_KEY=sk-replace-me

# ---- Embedder for Mem0 (local HuggingFace) ----
MEM0_EMBEDDER_PROVIDER=huggingface
MEM0_EMBEDDER_MODEL=sentence-transformers/all-MiniLM-L6-v2
MEM0_EMBEDDING_DIMS=384

# ---- (optional) real provider keys — unused if MEM0_LLM_* is set ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- CLI Binary Paths (resolved by the runtime) ----
# Default: the bare command via $PATH. Override only when the binary is
# in a non-standard location (e.g. ~/.local/bin/<bin> is not on PATH).
# CLAUDE_BIN=/absolute/path/to/claude
# HERMES_BIN=/absolute/path/to/hermes
# CURSOR_BIN=/absolute/path/to/agent
# GEMINI_BIN=/absolute/path/to/gemini
GEMINI_MODEL=gemini-2.5-flash

# ---- Logging ----
LOG_LEVEL=info
NODE_ENV=development
